# ============================================================
# GEM Crispy Confectonaries — Environment Variables Reference
# ============================================================
# This project has NO server-side .env file to load — it's a
# static site. This file documents the SECRETS you must set on
# Supabase (for the Edge Functions) and the values you must put
# into js/config.js (for the frontend). Nothing here is read
# automatically; it's a reference/checklist only.

# ---------- Frontend (js/config.js) ----------
# Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# ---------- Edge Function secrets ----------
# Set these with the Supabase CLI, e.g.:
#   supabase secrets set RESEND_API_KEY=re_xxx
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the Edge Runtime — do NOT set them yourself.

# Resend (transactional email — enquiry/contact form notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_FROM_EMAIL="GEM Website <notifications@gemcrispy.com>"
NOTIFY_TO_EMAIL=hello@gemcrispy.com

# Brevo (marketing email — newsletter subscriber sync)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_LIST_ID=1
